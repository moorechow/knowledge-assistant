# ============================================================
# DeepSeek API 接入（OpenAI 兼容）
# 官网: https://platform.deepseek.com
# ============================================================

OPENAI_API_KEY=your-deepseek-api-key-here
OPENAI_API_BASE=https://api.deepseek.com

# Chat 模型
#   deepseek-chat      — 最新 V3 模型，性价比高
#   deepseek-reasoner  — R1 推理模型
LLM_MODEL=deepseek-chat

# ============================================================
# Embedding：本地模型（无需 API，免费离线运行）
#   首次使用会自动下载模型文件，约 500MB
#   默认: BAAI/bge-small-zh-v1.5（512维，中文优化）
#   可选: paraphrase-multilingual-MiniLM-L12-v2（384维，多语言）
# ============================================================
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ============================================================
# 向量数据库（ChromaDB，嵌入式，无需单独安装）
# ============================================================
CHROMA_PERSIST_DIR=./data/chroma_db

# 日志级别
LOG_LEVEL=INFO
